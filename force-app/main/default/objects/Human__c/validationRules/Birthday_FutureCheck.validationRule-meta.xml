<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Birthday_FutureCheck</fullName>
    <active>true</active>
    <errorConditionFormula
  >AND (RecordType.Name = &quot;個人&quot;, Birthday__c&gt; TODAY() )</errorConditionFormula>
    <errorDisplayField>Birthday__c</errorDisplayField>
    <errorMessage>正しい生年月日を入力してください。</errorMessage>
</ValidationRule>
