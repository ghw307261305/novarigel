<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Experience_Check</fullName>
    <active>true</active>
    <errorConditionFormula
  >AND (RecordType.Name = &quot;個人&quot;, ISPICKVAL(Experience__c, &quot;&quot;) )</errorConditionFormula>
    <errorDisplayField>Experience__c</errorDisplayField>
    <errorMessage>学校活動経験を選択してください。</errorMessage>
</ValidationRule>
