<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ActivityWeekTime_Check</fullName>
    <active>true</active>
    <errorConditionFormula
  >AND (RecordType.Name = &quot;個人&quot;, ISBLANK(ActivityWeekTime__c) )</errorConditionFormula>
