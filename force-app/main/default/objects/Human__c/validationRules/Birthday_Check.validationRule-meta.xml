<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Birthday_Check</fullName>
    <active>true</active>
    <errorConditionFormula
  >AND (RecordType.Name = &quot;個人&quot;, ISBLANK(Birthday__c))</errorConditionFormula>
    <errorDisplayField>Birthday__c</errorDisplayField>
    <errorMessage>生年月日を入力してください。</errorMessage>
</ValidationRule>
