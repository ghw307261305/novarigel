<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Post_ValidCheck</fullName>
    <active>true</active>
    <errorConditionFormula
  >AND(RecordType.Name=&quot;個人&quot;, PostalCode__c!=&quot;&quot;,NOT(REGEX(PostalCode__c,&quot;[0-9]{7}+$&quot;)))</errorConditionFormula>
    <errorDisplayField>PostalCode__c</errorDisplayField>
    <errorMessage
  >郵便番号は７桁の半角数字をハイフンなしで入力してください。</errorMessage>
</ValidationRule>
