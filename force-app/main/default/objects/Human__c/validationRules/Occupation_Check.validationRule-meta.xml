<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Occupation_Check</fullName>
    <active>true</active>
    <errorConditionFormula
  >AND (RecordType.Name = &quot;個人&quot;, ISPICKVAL(Occupation__c, &quot;&quot;) )</errorConditionFormula>
    <errorDisplayField>Occupation__c</errorDisplayField>
    <errorMessage>現在の職業を選択してください。</errorMessage>
</ValidationRule>
